{
  "version": "1.0",
  "plan_store": {
    "mode": "external",
    "path": "projects",
    "_comment": "external = plans live in this Vidux repo. inline = plans live on a feature branch in the target project."
  },
  "defaults": {
    "archive_threshold": 30,
    "context_warning_lines": 200,
    "max_worktrees": 5,
    "stale_in_progress_days": 3,
    "max_browser_processes": 7,
    "max_codex_active_threads": 400,
    "max_codex_active_automation_threads": 250,
    "max_codex_avg_title_chars": 2000,
    "min_system_memory_free_pct": 15
  },
  "guidelines": {
    "cron_interval_minutes": 60,
    "max_parallel_agents": 4,
    "_comment": "Guidelines for agents reading this config. Not enforced by scripts."
  },
  "external_plan_roots": [],
  "dashboard": {
    "refresh_mode": "on-demand",
    "_comment": "on-demand (default), polling (5s), or tail. Start simple per Q7."
  },
  "ledger": {
    "path": "",
    "append_hook": "",
    "_comment": "Empty = auto-discover ~/.agent-ledger/. Per DL: ledger is centralized, not per-project."
  },
  "pruning": {
    "stale_blocked_days": 90,
    "decision_log_rotation_days": 180,
    "worktree_stale_hours": 24,
    "worktree_orphaned_hours": 48,
    "max_concurrent_worktrees": 3,
    "plan_size_warn_kb": 100
  },
  "backpressure": {
    "bimodal_warning_threshold": 85,
    "bimodal_critical_threshold": 70,
    "max_concurrent_dispatches": 4,
    "pressure_ceiling": 8,
    "circuit_breaker_failures": 3,
    "circuit_breaker_window_cycles": 5,
    "circuit_breaker_cooldown_cycles": 3
  }
}
