.DS_Store
__pycache__/
.pytest_cache/
.venv/
*.pyc
node_modules/
docs/.vitepress/dist/
.claudux/
QUEUE.jsonl

# Private project plans — never commit to public repo
# Plans are external-mode (vidux.config.json) and stay local.
# Use `projects/*` (not `projects/`) so subdirectory exceptions can re-include.
projects/*
# Exception: vidux-browser is internal-to-vidux tooling, ships with the code.
!projects/vidux-browser/

# Temp files from checkpoint script
tmp*.md

# External board sync sidecars
.external-state.json

# Claude Code local state
.claude/*
!.claude/settings.json

# Secrets / environment — never commit
.env
.env.*
*.key
*.pem
secrets/

# Browser runtime artifacts (user-generated HTML, not source)
browser/artifacts/*
!browser/artifacts/.gitkeep
